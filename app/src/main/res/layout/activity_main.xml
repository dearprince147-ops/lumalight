<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    tools:context=".MainActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/activateButton">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Pill Toggle for Modes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="16dp"
                android:background="@drawable/bg_pill_track"
                android:orientation="horizontal">
                
                <TextView
                    android:id="@+id/tabSolid"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/mode_solid"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_pill_thumb_selected" />

                <TextView
                    android:id="@+id/tabStrobe"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/mode_strobe"
                    android:textColor="#888888"
                    android:textStyle="bold"
                    android:background="@null" />
            </LinearLayout>

            <!-- Color 1 Section -->
            <LinearLayout
                android:id="@+id/color1Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/lblColor1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/color_1"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <View
                    android:id="@+id/colorSwatch1"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="#FFFFFF" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="24dp">

                    <LinearLayout
                        android:id="@+id/presetContainer1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <SeekBar
                    android:id="@+id/hueSlider1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="24dp"
                    android:max="360"
                    android:progress="0"
                    android:thumb="@drawable/slider_thumb"
                    android:splitTrack="false"
                    android:thumbOffset="0dp" />
            </LinearLayout>

            <!-- Strobe Settings (Speed + Color 2) -->
            <LinearLayout
                android:id="@+id/strobeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/strobe_speed"
                    android:textColor="#FFFFFF" />

                <SeekBar
                    android:id="@+id/strobeSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    android:thumb="@drawable/slider_thumb"
                    android:splitTrack="false"
                    android:max="19"
                    android:progress="9" /> <!-- 1-20 Hz mapped to 0-19 -->

                <TextView
                    android:id="@+id/lblColor2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/color_2"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/colorSwatch2"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="#000000" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="24dp">

                    <LinearLayout
                        android:id="@+id/presetContainer2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <SeekBar
                    android:id="@+id/hueSlider2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="24dp"
                    android:max="360"
                    android:progress="0"
                    android:thumb="@drawable/slider_thumb"
                    android:splitTrack="false"
                    android:thumbOffset="0dp" />

            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/ledToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:text="@string/toggle_led_torch"
                android:textColor="#FFFFFF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/activateButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="16dp"
        android:text="@string/activate"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0D0D0D"
        android:backgroundTint="#FFFFFF"
        app:cornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Full screen active overlay -->
    <FrameLayout
        android:id="@+id/activeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:id="@+id/activeFlashlightColor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF" />

        <TextView
            android:id="@+id/activeHintText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/active_hint"
            android:textColor="#50000000"
            android:textSize="24sp"
            android:textStyle="bold" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
